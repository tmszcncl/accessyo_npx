{
  "name": "accessyo",
  "version": "0.1.0",
  "description": "Network debugging CLI — see why your users can't connect",
  "keywords": [
    "network",
    "debugging",
    "dns",
    "tls",
    "tcp",
    "http",
    "diagnostics",
    "cli",
    "devops",
    "sre"
  ],
  "homepage": "https://accessyo.com",
  "bugs": {
    "url": "https://github.com/accessyo/accessyo/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/accessyo/accessyo.git"
  },
  "license": "MIT",
  "author": "Accessyo Contributors",
  "type": "module",
  "bin": {
    "accessyo": "./dist/cli.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "build:watch": "tsc -p tsconfig.build.json --watch",
    "clean": "rm -rf dist",
    "lint": "eslint src",
    "lint:fix": "eslint src --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "prebuild": "npm run clean",
    "prepublishOnly": "npm run lint && npm run format:check && npm run build",
    "dev": "tsx src/cli.ts",
    "test": "node --experimental-vm-modules node_modules/.bin/jest --passWithNoTests",
    "test:watch": "node --experimental-vm-modules node_modules/.bin/jest --watch",
    "typecheck": "tsc --noEmit",
    "test:coverage": "node --experimental-vm-modules node_modules/.bin/jest --coverage --passWithNoTests"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/jest": "^30.0.0",
    "@types/node": "^25.6.0",
    "eslint": "^10.2.0",
    "jest": "^30.3.0",
    "prettier": "^3.8.2",
    "ts-jest": "^29.4.9",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2",
    "typescript-eslint": "^8.58.1"
  },
  "dependencies": {
    "chalk": "^5.6.2",
    "commander": "^14.0.3",
    "ora": "^9.3.0",
    "undici": "^8.0.2"
  }
}
